# ============================================
# Supabase PostgreSQL Database
# ============================================
# DATABASE_URL: Connection pooler URL (for app runtime on Vercel)
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Get this from: Supabase Dashboard → Settings → Database → Connection string → URI → "Transaction pooler" mode
#
# DIRECT_URL: Direct connection URL (for Prisma migrations only)
#   Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
#   Get this from: Supabase Dashboard → Settings → Database → Connection string → URI → "Session" or "Direct" mode
#
# IMPORTANT: Both URLs must end with your database password
# ============================================

DATABASE_URL=postgresql://postgres.xxxxxx:[YOUR_PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxxx:[YOUR_PASSWORD]@db.xxxxxx.supabase.co:5432/postgres
