# ============================================
# Supabase PostgreSQL Database Configuration
# ============================================
# Get these values from your Supabase project:
# https://supabase.com/dashboard → Your Project → Settings → Database
#
# DATABASE_URL (Connection Pooler):
#   Use "Transaction" mode from Supabase Dashboard
#   This is used by the app at runtime (Vercel serverless functions)
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL (Direct Connection):
#   Use "Direct connection" or "Session" mode from Supabase Dashboard
#   This is only used for running Prisma migrations locally
#   Format: postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres
# ============================================

DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
